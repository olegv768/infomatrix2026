{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap-main.xml"
    },
    {
      "source": "/((?!sitemap-main.xml|sitemap.xml|robots.txt).*)",
      "destination": "/frontend/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap-main.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/xml; charset=UTF-8"
        }
      ]
    }
  ]
}
{
    "rewrites": [
        {
            "source": "/sitemap.xml",
            "destination": "/frontend/sitemap.xml"
        },
        {
            "source": "/robots.txt",
            "destination": "/frontend/robots.txt"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/index.html"
        }
    ],
    "headers": [
        {
            "source": "/sitemap.xml",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "text/xml; charset=utf-8"
                },
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex"
                }
            ]
        }
    ]
}